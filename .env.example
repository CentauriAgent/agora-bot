# Agora Bot Environment Configuration
# Copy to .env and fill in values

# Bot Nostr secret key (hex)
NOSTR_SECRET_KEY=

# Relays to subscribe to (comma-separated)
RELAYS=wss://relay.ditto.pub/,wss://relay.dreamith.to/

# Relays to publish announcements to (comma-separated)
PUBLISH_RELAYS=wss://relay.ditto.pub/,wss://relay.dreamith.to/,wss://relay.primal.net/,wss://nos.lol

# Data directory for SQLite database
DATA_DIR=./data

# Minimum interval between announcement posts (milliseconds)
POST_INTERVAL_MS=300000

# Log level (debug, info, warn, error)
LOG_LEVEL=info
